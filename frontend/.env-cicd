# ===========================================
# Build-time placeholders for CI/CD
# These are replaced at runtime by entrypoint.sh
# ===========================================

# --- Non NEXT_PUBLIC (replaced explicitly) ---
DOMAIN_NAME=DOMAIN_NAME_PLACEHOLDER
# basePath is baked into Next routing at build time, so it is not a runtime placeholder.
# Leave empty to serve at root; set a real value here if the app is served under a sub-path.
BASE_PATH=
ADMIN_URL=ADMIN_URL_PLACEHOLDER
HEALTH_AUTH="false"
HEALTH_USERNAME=HEALTH_USERNAME_PLACEHOLDER
HEALTH_PASSWORD=HEALTH_PASSWORD_PLACEHOLDER

# --- App (NEXT_PUBLIC_* replaced automatically by entrypoint.sh) ---
NEXT_PUBLIC_APP_NAME=NEXT_PUBLIC_APP_NAME_PLACEHOLDER
NEXT_PUBLIC_API_URL=NEXT_PUBLIC_API_URL_PLACEHOLDER
NEXT_PUBLIC_BASE_PATH=
NEXT_PUBLIC_PROTECTED_ROUTES=NEXT_PUBLIC_PROTECTED_ROUTES_PLACEHOLDER
