{
  "name": "@sk-web-gui/web-app-starter",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "yarn generate:middleware-envs",
    "dev": "cross-env TEST=true sh -c 'next dev -p ${1:-${PORT:-3000}}' --",
    "prebuild": "yarn generate:middleware-envs",
    "build": "next build",
    "prebuild:test": "yarn generate:middleware-envs",
    "build:test": "cross-env TEST=true next build",
    "start": "next start",
    "generate:middleware-envs": "node middleware-envs-generator.mjs",
    "generate:contracts": "cross-env NODE_ENV=development npx tsx ./src/swagger-typescript-api.ts",
    "lint": "eslint src/ e2e/",
    "lint:fix": "eslint src/ e2e/ --fix",
    "lint:strict": "eslint src/ e2e/ --max-warnings=0 --cache --cache-location node_modules/.cache/eslint/",
    "format": "prettier --write \"{src,e2e}/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"{src,e2e}/**/*.{ts,tsx}\"",
    "type-check": "tsc --pretty --noEmit",
    "knip": "knip",
    "knip:production": "knip --production",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "analyze": "cross-env ANALYZE=true next build",
    "analyze:server": "cross-env BUNDLE_ANALYZE=server next build",
    "analyze:browser": "cross-env BUNDLE_ANALYZE=browser next build"
  },
  "dependencies": {
    "@sk-web-gui/core": "4.3.3",
    "@sk-web-gui/react": "3.0.9",
    "@sk-web-gui/text-editor": "2.1.0",
    "axios": "^1.13.5",
    "dayjs": "^1.11.19",
    "docx-preview": "^0.3.7",
    "i18next": "^26.3.1",
    "i18next-resources-to-backend": "^1.2.1",
    "lodash": "^4.18.1",
    "lucide-react": "1.18.0",
    "next": "16.2.9",
    "next-i18n-router": "^5.5.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.71.2",
    "react-i18next": "^17.0.8",
    "sanitize-html": "^2.17.5",
    "sass": "^1.94.0",
    "sharp": "^0.35.1",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/container-queries": "^0.1.1",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/lodash": "^4.17.24",
    "@types/node": "^25.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/sanitize-html": "^2.16.1",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.9",
    "autoprefixer": "^10.4.21",
    "cross-env": "^10",
    "dotenv": "^17.4.2",
    "envalid": "^8.0.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.9",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-simple-import-sort": "^13",
    "eslint-plugin-unused-imports": "^4.4.1",
    "jsdom": "^25.0.1",
    "knip": "^6.14.2",
    "postcss": "^8.5.3",
    "postcss-import": "^16.1.0",
    "prettier": "^3.5.3",
    "swagger-typescript-api": "^13.0.28",
    "tailwindcss": "^3.4.17",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.57.2",
    "vite": "^8.0.0",
    "vite-tsconfig-paths": "^6",
    "vitest": "^4.1.9"
  },
  "browserslist": [
    "defaults and fully supports es6-module"
  ]
}
