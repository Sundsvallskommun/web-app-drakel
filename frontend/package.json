{
  "name": "@sk-web-gui/web-app-starter",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "yarn generate:middleware-envs",
    "dev": "cross-env TEST=true next dev",
    "prebuild": "yarn generate:middleware-envs",
    "build": "next build",
    "prebuild:test": "yarn generate:middleware-envs",
    "build:test": "cross-env TEST=true next build",
    "start": "next start",
    "generate:middleware-envs": "node middleware-envs-generator.mjs",
    "generate:contracts": "cross-env NODE_ENV=development npx tsx ./src/swagger-typescript-api.ts",
    "lint": "next lint --no-cache",
    "analyze": "cross-env ANALYZE=true next build",
    "analyze:server": "cross-env BUNDLE_ANALYZE=server next build",
    "analyze:browser": "cross-env BUNDLE_ANALYZE=browser next build",
    "cypress": "cypress open",
    "cypress:headless": "cross-env TEST=true npx cypress run --component && npx cypress run --e2e",
    "test": "yarn cypress",
    "coverage": "yarn nyc report --reporter=text-summary",
    "test:coverage": "yarn cypress:headless",
    "type-check": "tsc --pretty --noEmit"
  },
  "dependencies": {
    "@sk-web-gui/core": "4.3.3",
    "@sk-web-gui/react": "3.0.9",
    "axios": "^1.13.5",
    "dayjs": "^1.11.19",
    "i18next": "^24.2.3",
    "i18next-resources-to-backend": "^1.2.1",
    "lodash": "4.17.21",
    "lucide-react": "0.576.0",
    "next": "16.2.6",
    "next-i18n-router": "^5.5.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.71.2",
    "react-i18next": "^15.6.1",
    "sass": "^1.94.0",
    "sharp": "^0.34.5",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@babel/plugin-transform-private-methods": "^7.25.9",
    "@babel/preset-env": "^7.26.9",
    "@babel/preset-react": "^7.26.3",
    "@babel/preset-typescript": "^7.27.0",
    "@cypress/code-coverage": "^3.14.0",
    "@eslint/js": "^8.57.1",
    "@istanbuljs/nyc-config-typescript": "^1.0.2",
    "@simonsmith/cypress-image-snapshot": "^10.0.3",
    "@tailwindcss/container-queries": "^0.1.1",
    "@types/lodash": "^4.17.24",
    "@types/node": "^25.0.0",
    "@types/react": "19.1.0",
    "@types/react-dom": "19.1.1",
    "@typescript-eslint/eslint-plugin": "^8.29.0",
    "autoprefixer": "^10.4.21",
    "cross-env": "^7.0.3",
    "cypress": "^14.2.1",
    "dotenv": "^16.4.7",
    "envalid": "^8.0.0",
    "eslint": "^8.57.1",
    "eslint-config-next": "15.2.4",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-react-refresh": "^0.4.19",
    "postcss": "^8.5.3",
    "postcss-import": "^16.1.0",
    "postcss-nested": "^7.0.2",
    "postcss-nesting": "^13.0.1",
    "prettier": "^3.5.3",
    "swagger-typescript-api": "^13.0.28",
    "tailwindcss": "^3.4.17",
    "typescript": "5.8.2",
    "typescript-eslint": "^8.29.0"
  },
  "browserslist": [
    "defaults and fully supports es6-module"
  ]
}
