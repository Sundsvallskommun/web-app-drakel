./middleware-envs.js
middleware-envs.js

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.npmrc
.yarnrc

# vercel
.vercel
.npmrc
.yarnrc

# Generated OpenAPI specs — only an intermediate for contract generation, never committed
**/data-contracts/**/swagger.json
