{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "plugins": [
      {
        "name": "next"
      },
    ],
    "types": ["node", "vitest/globals", "@testing-library/jest-dom"]
  },
  "include": [
    "next-env.d.ts",
    "node_modules/dayjs/plugin/utc.d.ts",
    "**/*.ts",
    "**/*.tsx",
    "./*.js",
    ".next/types/**/*.ts",
  ],
  "exclude": ["node_modules", "vitest.config.ts"]
}
