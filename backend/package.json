{
  "name": "backend",
  "version": "0.0.1",
  "description": "TypeScript + Express + Routing Controllers API Server",
  "author": "",
  "license": "ISC",
  "scripts": {
    "start": "cross-env NODE_ENV=production node dist/server.js",
    "dev": "cross-env NODE_ENV=development nodemon",
    "generate:contracts": "cross-env NODE_ENV=development ts-node ./src/swagger-typescript-api.ts",
    "build": "tsc && tsc-alias",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "lint:strict": "eslint src/ --max-warnings=0 --cache --cache-location node_modules/.cache/eslint/",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "type-check": "tsc --pretty --noEmit",
    "knip": "knip",
    "knip:production": "knip --production",
    "deploy:prod": "npm run build && pm2 start ecosystem.config.js --only prod",
    "deploy:dev": "pm2 start ecosystem.config.js --only dev"
  },
  "dependencies": {
    "@node-saml/passport-saml": "^5.1.0",
    "axios": "^1.13.5",
    "body-parser": "^2.3.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "class-validator-jsonschema": "^5.0.1",
    "compression": "^1.7.5",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "envalid": "^8.1.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "express-session": "^1.18.1",
    "form-data": "^4.0.6",
    "helmet": "^8.0.0",
    "hpp": "^0.2.3",
    "memorystore": "^1.6.7",
    "morgan": "^1.10.1",
    "passport": "^0.7.0",
    "qs": "^6.15.2",
    "reflect-metadata": "^0.2.2",
    "routing-controllers": "^0.11.3",
    "routing-controllers-openapi": "^5.0.1",
    "session-file-store": "^1.5.0",
    "swagger-ui-express": "^5.0.1",
    "tslib": "^2.8.1",
    "winston": "^3.17.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@swc/core": "^1.13.5",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/express-session": "^1.18.1",
    "@types/hpp": "^0.2.6",
    "@types/morgan": "^1.9.9",
    "@types/node": "^25",
    "@types/passport": "^1.0.17",
    "@types/qs": "^6.15.1",
    "@types/swagger-ui-express": "^4.1.7",
    "@vitest/coverage-v8": "^4.1.9",
    "cross-env": "^10",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-simple-import-sort": "^13",
    "eslint-plugin-unused-imports": "^4.4.1",
    "knip": "^6.14.2",
    "nodemon": "^3.1.9",
    "prettier": "^3.4.2",
    "swagger-typescript-api": "^13.0.23",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.10",
    "tsconfig-paths": "^4.2.0",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.57.2",
    "unplugin-swc": "^1.5.7",
    "vite-tsconfig-paths": "^6",
    "vitest": "^4.1.9"
  },
  "resolutions": {
    "@types/express": "^5.0.0",
    "@types/express-serve-static-core": "^5.1.1",
    "qs": ">=6.14.1",
    "form-data": ">=4.0.4",
    "multer": ">=2.1.0"
  }
}
